POSTGRES_PASSWORD=change_me

# ============================================================
# Embeddings 配置
# ============================================================

# Embedding 提供方式：
# - local_sentence_transformers: 本地 CPU 嵌入 via sentence-transformers (torch) (默认)
# - localhash: 零依赖备选方案（质量较低）
# - openai_compatible: 调用外部 OpenAI-compatible /embeddings 端点
EMBEDDING_PROVIDER=local_sentence_transformers

# 当 EMBEDDING_PROVIDER=local_sentence_transformers 时：
# 默认模型: intfloat/multilingual-e5-small (384d, 多语言)
# 注意: SEKS 假设使用 384 维（PostgreSQL schema 使用 vector(384)）
EMBEDDING_MODEL=intfloat/multilingual-e5-small
EMBEDDING_DIM=384

# 性能/资源调优
# 0 表示"使用默认值"；在小 CPU 上可设为 2 或 4
EMBEDDING_THREADS=0
# 通常用 "cpu"（只有构建 GPU 镜像时才能用 "cuda"）
EMBEDDING_DEVICE=cpu

# Hugging Face 缓存与网络（可选）
# 缓存目录默认在容器内 /data/cache
# CACHE_DIR=/data/cache
# SENTENCE_TRANSFORMERS_HOME=/data/cache/sentence-transformers
# HF_HOME=/data/cache/hf

# 可选：Hugging Face token，用于更快的模型下载
# HF_TOKEN=hf_xxx

# 可选：使用 Hugging Face Hub 镜像/端点（受限网络时有用）
# HF_ENDPOINT=https://huggingface.co

# 可选：增加单个请求超时（默认约 10 秒，慢网可能会卡住）
# HF_HUB_DOWNLOAD_TIMEOUT=60
# HF_HUB_ETAG_TIMEOUT=60

# 当 EMBEDDING_PROVIDER=openai_compatible 时：
# OpenAI-compatible /embeddings 端点
# 示例:
# https://api.openai.com/v1
# https://<your-gateway>/v1
EMBEDDING_BASE_URL=https://example.com/v1
# 某些自托管网关不需要 key，此时留空
EMBEDDING_API_KEY=change_me

# ============================================================
# 检索 / Rerank 配置
# ============================================================

# 是否启用轻量 rerank（Search 默认使用）
RETRIEVAL_RERANK_ENABLED=true

# 检索 top_k 的硬上限
RETRIEVAL_TOPK_MAX=50

# 每路召回的候选数 = top_k * multiplier
RETRIEVAL_CANDIDATE_MULTIPLIER=3

# 关键词检索最多使用的 term 数量
RETRIEVAL_KEYWORD_MAX_TERMS=6

# 各检索通道权重（融合时相加）
RETRIEVAL_WEIGHT_FTS=1.0
RETRIEVAL_WEIGHT_VECTOR=0.7
RETRIEVAL_WEIGHT_KEYWORD=0.6

# Ask 自身是否启用 rerank（默认跟随 RETRIEVAL_RERANK_ENABLED）
ASK_RERANK_ENABLED=true

# ============================================================
# LLM 配置（用于 /ask 接口的答案生成）
# ============================================================

# 是否启用 LLM。若设为 false 或留空，/ask 将使用 retrieval-only 模式
LLM_ENABLED=false

# OpenAI-compatible LLM 端点 URL
# 示例:
# https://api.openai.com/v1
# https://<your-gateway>/v1
# https://<node>.tailscale.ts.net/v1
LLM_BASE_URL=https://example.com/v1

# API Key（某些自托管网关可能不需要）
LLM_API_KEY=change_me

# 模型名称（需与 LLM_BASE_URL 配合使用）
# 示例: gpt-4o, gpt-5.4, qwen-plus, deepseek-chat 等
LLM_MODEL=gpt-5.4

# LLM 温度参数 (0.0-2.0)，默认 0.2
LLM_TEMPERATURE=0.2

# LLM 请求超时（秒），默认 60
LLM_TIMEOUT=60
